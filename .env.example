# ── Core ──
NODE_ENV=development

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neofilm?schema=public

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth ──
JWT_SECRET=change-this-in-production-minimum-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_SALT_ROUNDS=12

# ── NestJS API ──
API_PORT=3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# ── Next.js Apps ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXTAUTH_SECRET=change-this-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
WEB_ADMIN_PORT=3000
WEB_PARTNER_PORT=3002
WEB_ADVERTISER_PORT=3003

# ── S3 / MinIO ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_CREATIVES=neofilm-creatives
S3_BUCKET_UPLOADS=neofilm-uploads
CDN_BASE_URL=http://localhost:9000/neofilm-creatives

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# ── MQTT ──
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Monitoring ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=debug

# ── Email (Mailpit) ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@neofilm.io

# ── OAuth Google ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback

# ── Canva Connect API ──
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://localhost:3001/api/v1/integrations/canva/callback
CANVA_ENCRYPTION_KEY=  # 64 hex chars (32 bytes) for AES-256-GCM token encryption

# ── IPTV ──
IPTV_M3U_URL=https://raw.githubusercontent.com/Free-TV/IPTV/master/playlists/playlist_france.m3u8

# ── Frontend Redirect URLs (OAuth callback) ──
API_BASE_URL=http://localhost:3001
PARTNER_APP_URL=http://localhost:3002
ADVERTISER_APP_URL=http://localhost:3003
