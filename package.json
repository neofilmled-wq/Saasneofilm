{
  "name": "neofilm-saas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @neofilm/api dev",
    "dev:admin": "pnpm --filter @neofilm/web-admin dev",
    "dev:partner": "pnpm --filter @neofilm/web-partner dev",
    "dev:advertiser": "pnpm --filter @neofilm/web-advertiser dev",
    "dev:tv": "pnpm --filter @neofilm/tv-app dev",
    "dev:portal": "pnpm --filter @neofilm/web-portal dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @neofilm/database exec prisma generate",
    "db:migrate": "pnpm --filter @neofilm/database exec prisma migrate dev",
    "db:push": "pnpm --filter @neofilm/database exec prisma db push",
    "db:studio": "pnpm --filter @neofilm/database exec prisma studio",
    "test": "turbo test",
    "db:seed": "pnpm --filter @neofilm/database exec prisma db seed",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:reset": "pnpm db:push && pnpm db:seed",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^5.7.0",
    "prettier": "^3.5.0",
    "eslint": "^9.20.0",
    "@eslint/js": "^9.20.0",
    "typescript-eslint": "^8.25.0",
    "globals": "^15.15.0"
  }
}
